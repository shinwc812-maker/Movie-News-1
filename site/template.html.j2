<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<meta name="robots" content="noindex, nofollow, noarchive, nosnippet, noimageindex">
<meta name="googlebot" content="noindex, nofollow, noarchive">
<title>오늘의 영화/문화 레이더</title>
<style>{{ css|safe }}</style>
</head>
<body class="lang-ko">

{%- macro official_card(a, compact=False) -%}
<article class="card {% if compact %}card-compact{% endif %}">
  {% if a.image_url and not compact %}<img class="thumb" src="{{ a.image_url }}" alt="" loading="lazy" onerror="this.style.display='none'">{% endif %}
  <div class="card-body">
    <a class="title" href="{{ a.url }}" target="_blank" rel="noopener">
      <span class="lang-ko">{{ a.ko_title }}</span><span class="lang-en">{{ a.en_title }}{% if a.country == 'KR' %} <em class="kr-tag">(한국어)</em>{% endif %}</span>
    </a>
    <div class="meta">
      <span class="source official">공식 · {{ a.source }}</span>
      {% if a.rel_time %}<span class="time">{{ a.rel_time }}</span>{% endif %}
    </div>
    {% if a.ko_summary or a.en_summary %}
    <p class="summary">
      <span class="lang-ko">{{ a.ko_summary }}</span><span class="lang-en">{{ a.en_summary }}</span>
    </p>
    {% endif %}
    {% if a.matched_keywords %}
    <div class="chips">{% for kw in a.matched_keywords[:3] %}<span>{{ kw }}</span>{% endfor %}</div>
    {% endif %}
  </div>
</article>
{%- endmacro -%}

{%- macro community_card(c, extra=False) -%}
<article class="community-snapshot-card{% if extra %} is-extra{% endif %}">
  <div class="community-topline">
    <span>{{ c.source }}</span>
    {% if c.rel_time %}<em>{{ c.rel_time }}</em>{% endif %}
  </div>
  <a class="community-title" href="{{ c.url }}" target="_blank" rel="noopener">{{ c.title }}</a>
  {% if c.mood_summary %}<p class="community-mood">{{ c.mood_summary }}</p>{% endif %}
  {% if c.excerpt %}<p class="community-excerpt">{{ c.excerpt }}</p>{% endif %}
  {% if c.matched_keywords %}
  <div class="trend-meta community-keywords">{% for kw in c.matched_keywords[:3] %}<b>{{ kw }}</b>{% endfor %}</div>
  {% endif %}
</article>
{%- endmacro -%}

{%- macro curation_brief_card(item, extra=False) -%}
<article class="curation-brief-card{% if extra %} is-extra{% endif %}">
  <a class="title curation-article-title" href="{{ item.url }}" target="_blank" rel="noopener">{{ item.curation_title or item.title }}</a>
  {% if item.curation_summary %}
  <div class="curation-summary-block">
    <b>내용 요약</b>
    <p>{{ item.curation_summary }}</p>
  </div>
  {% endif %}
  <div class="brief-card-meta">
    <span class="source {% if item.content_kind == 'policy' %}policy{% else %}official{% endif %}">
      {% if item.content_kind == 'policy' %}정책{% else %}공식{% endif %} · {{ item.source }}
    </span>
    {% if item.rel_time %}<span class="time">{{ item.rel_time }}</span>{% endif %}
  </div>
  {% if item.matched_keywords %}
  <div class="chips">{% for kw in item.matched_keywords[:3] %}<span>{{ kw }}</span>{% endfor %}</div>
  {% endif %}
</article>
{%- endmacro -%}

{%- macro ai_briefing_panel(b) -%}
<section class="panel ai-briefing-panel" data-section="aiBriefing">
  <div class="ai-briefing-head">
    <span class="ai-badge">AI SUMMARY</span>
    <span class="ai-generated-at">{{ b.generated_at_kst or '' }} · Claude 자동 생성</span>
  </div>

  <div class="ai-cat-stack">
    {% for cat in b.categories or [] %}
    {% if cat["items"] %}
    <div class="ai-block ai-category">
      <div class="ai-block-head"><h3>{{ cat.name }}</h3></div>
      <ul class="ai-points">
        {% for it in cat["items"] %}
        <li>{{ it.summary_html|default(it.summary)|safe }}{% if it.source %} {% if it.source_url %}<a class="ai-cite" href="{{ it.source_url }}" target="_blank" rel="noopener">[{{ it.source }}]</a>{% else %}<span class="ai-cite">[{{ it.source }}]</span>{% endif %}{% endif %}</li>
        {% endfor %}
      </ul>
    </div>
    {% endif %}
    {% endfor %}
    {% if not b.categories %}<p class="empty">표시할 AI 브리핑이 없습니다.</p>{% endif %}
  </div>

</section>
{%- endmacro -%}

{%- macro archive_card_article(a) -%}
<article class="archive-card" data-kind="article">
  <a class="archive-title" href="{{ a.url }}" target="_blank" rel="noopener">{{ a.ko_title or a.title }}</a>
  <div class="archive-meta">
    <span class="archive-kind official">기사 · {{ a.source }}</span>
    {% if a.rel_time %}<span class="time">{{ a.rel_time }}</span>{% endif %}
  </div>
  {% if a.ko_summary or a.en_summary %}<p class="archive-excerpt">{{ a.ko_summary or a.en_summary }}</p>{% endif %}
  {% if a.matched_keywords %}<div class="chips">{% for kw in a.matched_keywords[:4] %}<span>{{ kw }}</span>{% endfor %}</div>{% endif %}
</article>
{%- endmacro -%}

{%- macro archive_card_community(c) -%}
<article class="archive-card" data-kind="community">
  <a class="archive-title" href="{{ c.url }}" target="_blank" rel="noopener">{{ c.title }}</a>
  <div class="archive-meta">
    <span class="archive-kind community">커뮤니티 · {{ c.source }}</span>
    {% if c.rel_time %}<span class="time">{{ c.rel_time }}</span>{% endif %}
  </div>
  {% if c.mood_summary %}<p class="archive-mood">{{ c.mood_summary }}</p>{% endif %}
  {% if c.excerpt %}<p class="archive-excerpt">{{ c.excerpt }}</p>{% endif %}
  {% if c.matched_keywords %}<div class="chips">{% for kw in c.matched_keywords[:4] %}<span>{{ kw }}</span>{% endfor %}</div>{% endif %}
</article>
{%- endmacro -%}

{%- macro market_trend_card(t) -%}
<article class="market-trend-card">
  <div class="trend-topline">
    <span>{{ t.category }}</span>
    {% if t.rel_time %}<em>{{ t.rel_time }}</em>{% endif %}
  </div>
  <a class="trend-title" href="{{ t.url }}" target="_blank" rel="noopener">{{ t.title }}</a>
  {% if t.frame %}<p class="trend-frame">{{ t.frame }}</p>{% endif %}
  {% if t.note %}
  <div class="trend-brief trend-note">
    <b>요약</b>
    <p>{{ t.note|replace('내용: ', '') }}</p>
  </div>
  {% endif %}
  <div class="trend-meta">
    <span>{{ t.source }}</span>
    {% for keyword in t.keywords[:3] %}<b>{{ keyword }}</b>{% endfor %}
  </div>
</article>
{%- endmacro -%}

<header class="topbar">
  <div>
    <p class="eyebrow">Internal Briefing</p>
    <h1>오늘의 영화/문화 레이더</h1>
    <p class="updated">마지막 업데이트: {{ updated_at }} (KST)</p>
  </div>
  <div class="topbar-tools">
    <form class="search-box" role="search" onsubmit="return RADAR.onSearchSubmit(event)">
      <input id="searchInput" type="search" placeholder="키워드 검색 (기사·커뮤니티)" autocomplete="off" aria-label="키워드 검색">
      <button type="submit" class="tool-btn">검색</button>
    </form>
    <div class="settings-wrap">
      <button type="button" class="tool-btn settings-btn" aria-haspopup="true" aria-expanded="false" onclick="RADAR.toggleSettings()">⚙️ 설정</button>
      <div id="settingsPanel" class="settings-panel" hidden>
        <p class="settings-title">섹션 표시</p>
        <div id="settingsList" class="settings-list"></div>
      </div>
    </div>
  </div>
</header>

<main class="dashboard">
  <div id="searchStatus" class="search-status" hidden>
    <span id="searchStatusText"></span>
    <button type="button" class="tool-btn" onclick="RADAR.clearSearch()">전체 보기</button>
  </div>
  <section class="kpis" aria-label="핵심 지표">
    <div class="kpi"><span>전일 총 입장객</span><strong>{% if market_summary %}{{ market_summary.total_audi }}명{% if market_summary.total_audi_delta %} <span class="audi-delta audi-delta-{{ market_summary.total_audi_delta_sign }}">({{ market_summary.total_audi_delta }})</span>{% endif %}{% else %}데이터 없음{% endif %}</strong></div>
    <div class="kpi"><span>평균 좌석판매율</span><strong>{% if market_summary %}{{ market_summary.avg_seat_sales }}{% else %}데이터 없음{% endif %}</strong></div>
    <div class="kpi kpi-chart"><span>전일 입장객 비중</span>
      {% if market_summary and market_summary.audi_chart %}
      <div class="kpi-pie-wrap">
        <div class="kpi-pie" style="background:{{ market_summary.audi_chart }}"></div>
        <ul class="kpi-legend">
          {% for s in market_summary.audi_legend %}<li><i style="background:{{ s.color }}"></i><span class="kpi-leg-title">{{ s.title }}</span> {{ s.pct }}%</li>{% endfor %}
        </ul>
      </div>
      {% else %}<strong>데이터 없음</strong>{% endif %}
    </div>
    <div class="kpi kpi-chart"><span>실시간 예매량 비중</span>
      {% if market_summary and market_summary.res_chart %}
      <div class="kpi-pie-wrap">
        <div class="kpi-pie" style="background:{{ market_summary.res_chart }}"></div>
        <ul class="kpi-legend">
          {% for s in market_summary.res_legend %}<li><i style="background:{{ s.color }}"></i><span class="kpi-leg-title">{{ s.title }}</span> {{ s.pct }}%</li>{% endfor %}
        </ul>
      </div>
      {% else %}<strong>데이터 없음</strong>{% endif %}
    </div>
  </section>

  <section class="briefing-grid">
      <section class="panel" data-section="boxoffice">
        <div class="panel-head">
          <h2>전일 입장객 TOP 5</h2>
          <span>KOBIS</span>
        </div>
        <ol class="boxoffice-list">
          {% for movie in boxoffice %}
          <li>
            <div class="boxoffice-title">
              <b>{{ movie.rank }}</b>
              <span>{{ movie.rank }}위: {{ movie.title }}{% if movie.open_date %} <em>(개봉 {{ movie.open_date }})</em>{% endif %}</span>
            </div>
            <dl class="boxoffice-metrics">
              <div><dt>관객수</dt><dd>{{ movie.audi_count }}명</dd></div>
              <div><dt>전일대비</dt><dd><span class="audi-delta audi-delta-{{ movie.audi_delta_sign }}">{{ movie.audi_delta }}</span> / 누적관객수: {{ movie.audi_acc }}명</dd></div>
              {% if movie.seat_metrics_available %}
              <div><dt>좌석</dt><dd>좌석수: {{ movie.seat_count }}석 / 좌점율: {{ movie.seat_share }} / 좌판율: {{ movie.seat_sales_rate }}</dd></div>
              {% else %}
              <div><dt>좌석</dt><dd>좌석 데이터 없음</dd></div>
              {% endif %}
            </dl>
          </li>
          {% endfor %}
        </ol>
        {% if not boxoffice %}<p class="empty">KOBIS 박스오피스 데이터가 없습니다.</p>{% endif %}
      </section>

      <aside class="briefing-side-stack">
      <section class="panel" data-section="reservation">
        <div class="panel-head">
          <h2>실시간 예매량 TOP 5</h2>
          <span>예매량(예매율)</span>
        </div>
        <ol class="reservation-list">
          {% for movie in reservation.movies %}
          <li>
            <b>{{ movie.rank }}</b>
            <span>{{ movie.title }}</span>
            <strong>{{ movie.reservation_label }}</strong>
          </li>
          {% endfor %}
        </ol>
        {% if not reservation.movies %}<p class="empty">KOBIS 예매율 데이터가 없습니다.</p>{% endif %}
      </section>

      <section class="panel" data-section="overseas">
        <div class="panel-head">
          <h2>북미 주말 TOP 5</h2>
          <span>Box Office Mojo{% if overseas_weekend.weekend_label %} · {{ overseas_weekend.weekend_label }}{% endif %}</span>
        </div>
        <ol class="overseas-weekend-list">
          {% for movie in overseas_weekend.movies %}
          <li>
            <b>{{ movie.rank }}</b>
            {% if movie.url %}
            <a href="{{ movie.url }}" target="_blank" rel="noopener">{{ movie.title }}</a>
            {% else %}
            <span>{{ movie.title }}</span>
            {% endif %}
            <strong>{{ movie.gross }}</strong>
          </li>
          {% endfor %}
        </ol>
        {% if not overseas_weekend.movies %}<p class="empty">Box Office Mojo 데이터가 없습니다.</p>{% endif %}
      </section>
    </aside>
  </section>

  {% if ai_briefing %}{{ ai_briefing_panel(ai_briefing) }}{% endif %}

  <div class="ai-briefing-toggle">
    <button type="button" class="dashboard-toggle-btn" onclick="RADAR.toggleDashboard()">
      <span class="dt-label">기사 펼치기 ▼</span>
      <span class="dt-sub">오늘의 영화/문화 레이더 — 박스오피스·기사·커뮤니티 등 원문 데이터</span>
    </button>
  </div>

  <section class="hero-grid">
    <div class="panel curation-panel">
      <div class="panel-head">
        <h2>핵심 큐레이션</h2>
        <span>sectioned executive brief</span>
      </div>
      <div class="curation-sections" data-section-order="흥행·배급|극장·정책|경쟁사·산업|해외·마켓|드라마·OTT">
        {% for section in curation_sections %}
        <section class="curation-section">
          <div class="curation-section-head">
            <div>
              <h3>{{ section.title }}</h3>
              <span>{{ section.eyebrow }}</span>
            </div>
            <div class="curation-section-meta">
              <b>{{ section["items"]|length }}건</b>
              {% if section["items"]|length > 2 %}<button type="button" class="curation-more-btn" aria-expanded="false">더보기</button>{% endif %}
            </div>
          </div>
          <div class="curation-section-items">
            {% for item in section["items"] %}{{ curation_brief_card(item, extra=loop.index > 2) }}{% endfor %}
          </div>
        </section>
        {% endfor %}
        {% if not curation_sections %}<p class="empty">표시할 큐레이션 항목이 없습니다.</p>{% endif %}
      </div>
    </div>

  </section>

  <section class="panel market-trends-panel">
    <div class="panel-head">
      <h2>시장동향 / Live·IP·팝업</h2>
      <span>experience business scan</span>
    </div>
    <div class="section-stack market-section-stack">
      {% for section in market_trend_sections %}
      <section class="briefing-subsection">
        <div class="section-head">
          <h3>{{ section.title }}</h3>
          <span>{{ section.count }}건</span>
        </div>
        <div class="market-trends-grid section-card-grid">
          {% for trend in section["items"] %}{{ market_trend_card(trend) }}{% endfor %}
        </div>
      </section>
      {% endfor %}
    </div>
    {% if not market_trends %}<p class="empty">표시할 시장동향 스크랩이 없습니다.</p>{% endif %}
  </section>

  <section class="community-only-panel">
    <div class="panel">
      <div class="panel-head">
        <h2>커뮤니티 반응</h2>
        <span>본문/댓글 분위기 요약</span>
      </div>
      <div class="section-stack community-sections">
        {% for section in community_sections %}
        <section class="briefing-subsection community-source-section">
          <div class="section-head">
            <h3>{{ section.title }}</h3>
            <div class="community-section-meta">
              <span>{{ section.count }}건</span>
              {% if section["items"]|length > 4 %}<button type="button" class="community-more-btn" aria-expanded="false">더보기</button>{% endif %}
            </div>
          </div>
          <div class="community-card-grid section-card-grid">
            {% for reaction in section["items"] %}{{ community_card(reaction, extra=loop.index > 4) }}{% endfor %}
          </div>
        </section>
        {% endfor %}
        {% if not community_reactions %}<p class="empty">표시할 커뮤니티 반응이 없습니다.</p>{% endif %}
      </div>
    </div>
  </section>

  <section class="panel policy-panel">
    <div class="panel-head">
      <h2>정책/지원</h2>
      <span>영화·문화 공공 지원</span>
    </div>
    <div class="policy-grid">
      {% for policy in policy_items[:8] %}
      <a class="policy-card" href="{{ policy.url }}" target="_blank" rel="noopener">
        <span>{{ policy.source }} · {{ policy.category }}</span>
        <strong>{{ policy.title }}</strong>
        {% if policy.summary %}<em>{{ policy.summary }}</em>{% endif %}
      </a>
      {% endfor %}
    </div>
    {% if not policy_items %}<p class="empty">표시할 정책/지원 공지가 없습니다.</p>{% endif %}
  </section>

  <section class="panel search-archive-panel" data-section="archive">
    <div class="panel-head">
      <h2>전체 수집 검색결과</h2>
      <span>키워드 검색 시 수집분 전체({{ archive_total }}건)에서 매칭 표시</span>
    </div>
    <div class="archive-group" data-archive-group="article">
      <div class="section-head"><h3>기사</h3><span>{{ archive_official|length }}건</span></div>
      <div class="archive-list">
        {% for a in archive_official %}{{ archive_card_article(a) }}{% endfor %}
      </div>
    </div>
    <div class="archive-group" data-archive-group="community">
      <div class="section-head"><h3>커뮤니티</h3><span>{{ archive_community|length }}건</span></div>
      <div class="archive-list">
        {% for c in archive_community %}{{ archive_card_community(c) }}{% endfor %}
      </div>
    </div>
    {% if not archive_official and not archive_community %}<p class="empty">수집된 항목이 없습니다.</p>{% endif %}
  </section>
</main>

<footer>내부용 영화/문화 이슈 집계 · 자동 생성</footer>

<script>
(function () {
  var SETTINGS_KEY = 'radar.sections.v1';
  // 설정에서 표시/숨김을 토글할 수 있는 섹션 목록
  var SECTIONS = [
    { key: 'aiBriefing',  label: 'AI 브리핑',       sel: '.ai-briefing-panel' },
    { key: 'kpis',        label: '핵심 지표',       sel: '.kpis' },
    { key: 'curation',    label: '핵심 큐레이션',   sel: '.curation-panel' },
    { key: 'boxoffice',   label: '전일 입장객 TOP 5', sel: '[data-section="boxoffice"]' },
    { key: 'reservation', label: '실시간 예매량',   sel: '[data-section="reservation"]' },
    { key: 'overseas',    label: '북미 주말 TOP 5', sel: '[data-section="overseas"]' },
    { key: 'market',      label: '시장동향',        sel: '.market-trends-panel' },
    { key: 'community',   label: '커뮤니티 반응',   sel: '.community-only-panel' },
    { key: 'policy',      label: '정책/지원',       sel: '.policy-panel' }
  ];
  // 검색은 '전체 수집' 아카이브(.archive-card)에서만 수행한다. 일반 패널은 검색 중
  // CSS(body.is-searching)로 숨기고, 매칭 결과는 아카이브에 모아 보여준다(중복 없음).
  var ARCHIVE_CARD_SEL = '.archive-card';

  var settings = {};
  var term = '';      // 소문자
  var rawTerm = '';   // 표시용 원본

  // 메인 화면 첫 진입은 AI 브리핑만 노출. '기사 펼치기'로 대시보드 본문 토글.
  var DASHBOARD_OPEN_KEY = 'radar.dashboardOpen.v1';
  var dashboardOpen = false;

  function q(sel) { return document.querySelector(sel); }
  function qa(sel) { return Array.prototype.slice.call(document.querySelectorAll(sel)); }
  function setVisible(el, vis) { if (el) el.style.display = vis ? '' : 'none'; }
  function visibleBySetting(key) { return settings[key] !== false; }

  function loadSettings() {
    settings = {};
    try {
      var raw = localStorage.getItem(SETTINGS_KEY);
      if (raw) { settings = JSON.parse(raw) || {}; }
    } catch (e) { settings = {}; }
  }
  function saveSettings() {
    try { localStorage.setItem(SETTINGS_KEY, JSON.stringify(settings)); } catch (e) {}
  }

  function loadDashboardOpen() {
    try { dashboardOpen = localStorage.getItem(DASHBOARD_OPEN_KEY) === '1'; }
    catch (e) { dashboardOpen = false; }
  }
  function saveDashboardOpen() {
    try { localStorage.setItem(DASHBOARD_OPEN_KEY, dashboardOpen ? '1' : '0'); }
    catch (e) {}
  }
  function toggleDashboard() {
    dashboardOpen = !dashboardOpen;
    saveDashboardOpen();
    apply();
  }
  function updateDashboardToggleLabel() {
    var label = q('.dashboard-toggle-btn .dt-label');
    if (label) { label.textContent = dashboardOpen ? '기사 접기 ▲' : '기사 펼치기 ▼'; }
  }

  function apply() {
    var searching = term.length > 0;
    document.body.classList.toggle('is-searching', searching);

    if (searching) {
      // 검색 중: 일반 패널은 CSS(body.is-searching)가 숨긴다. '전체 수집' 아카이브에서만 매칭.
      var n = 0;
      qa(ARCHIVE_CARD_SEL).forEach(function (card) {
        var hit = card.textContent.toLowerCase().indexOf(term) !== -1;
        card.style.display = hit ? '' : 'none';
        if (hit) { n++; }
      });
      // 매칭 카드가 하나도 없는 그룹(기사/커뮤니티)은 머리글째 숨긴다.
      qa('.archive-group').forEach(function (group) {
        var cards = Array.prototype.slice.call(group.querySelectorAll(ARCHIVE_CARD_SEL));
        group.style.display = cards.some(function (c) { return c.style.display !== 'none'; }) ? '' : 'none';
      });
      var status = q('#searchStatus');
      if (status) {
        q('#searchStatusText').textContent = '검색 “' + rawTerm + '” · ' + n + '건';
        status.hidden = false;
      }
    } else {
      // 평소: 아카이브는 CSS로 숨김. 대시보드 본문은 dashboardOpen 토글에 따름.
      //  - 접힘(기본): body.dashboard-collapsed 추가 → CSS가 핵심 큐레이션·시장동향·커뮤니티만 숨김.
      //    KPI, AI 브리핑, 사이드 TOP5 3개는 항상 설정대로 노출.
      //  - 펼침: 클래스 제거 + 모든 SECTIONS를 설정대로 복구.
      document.body.classList.toggle('dashboard-collapsed', !dashboardOpen);
      if (dashboardOpen) {
        SECTIONS.forEach(function (s) { setVisible(q(s.sel), visibleBySetting(s.key)); });
      } else {
        // 접힘 상태에서도 KPI, AI 브리핑, 사이드 TOP5 3개는 설정대로 노출 처리.
        setVisible(q('.ai-briefing-panel'), visibleBySetting('aiBriefing'));
        setVisible(q('.kpis'), visibleBySetting('kpis'));
        ['boxoffice', 'reservation', 'overseas'].forEach(function (k) {
          setVisible(q('[data-section="' + k + '"]'), visibleBySetting(k));
        });
      }
      var briefingSidestack = q('.briefing-side-stack');
      if (briefingSidestack) {
        setVisible(briefingSidestack,
          visibleBySetting('reservation') || visibleBySetting('overseas'));
      }
      updateDashboardToggleLabel();
      var status = q('#searchStatus');
      if (status) { status.hidden = true; }
    }
  }

  function runSearch(value) {
    rawTerm = (value || '').trim();
    term = rawTerm.toLowerCase();
    apply();
  }
  function clearSearch() {
    rawTerm = ''; term = '';
    var input = q('#searchInput'); if (input) { input.value = ''; }
    apply();
  }
  function onSearchSubmit(e) {
    e.preventDefault();
    runSearch(q('#searchInput').value);
    return false;
  }

  function buildSettings() {
    var list = q('#settingsList');
    if (!list) { return; }
    list.innerHTML = '';
    SECTIONS.forEach(function (s) {
      var label = document.createElement('label');
      label.className = 'settings-item';
      var cb = document.createElement('input');
      cb.type = 'checkbox';
      cb.checked = visibleBySetting(s.key);
      cb.addEventListener('change', function () {
        settings[s.key] = cb.checked;
        saveSettings();
        apply();
      });
      var span = document.createElement('span');
      span.textContent = s.label;
      label.appendChild(cb);
      label.appendChild(span);
      list.appendChild(label);
    });
  }
  function toggleSettings() {
    var panel = q('#settingsPanel');
    var btn = q('.settings-btn');
    if (!panel) { return; }
    var show = panel.hidden;
    panel.hidden = !show;
    if (btn) { btn.setAttribute('aria-expanded', show ? 'true' : 'false'); }
  }
  // 패널 바깥 클릭 시 닫기
  document.addEventListener('click', function (e) {
    var wrap = q('.settings-wrap');
    var panel = q('#settingsPanel');
    if (!wrap || !panel || panel.hidden) { return; }
    if (!wrap.contains(e.target)) {
      panel.hidden = true;
      var btn = q('.settings-btn'); if (btn) { btn.setAttribute('aria-expanded', 'false'); }
    }
  });

  // 섹션 "더보기/접기": 기본 일부만 노출, 클릭 시 전체 표시 (큐레이션·커뮤니티 공용)
  function bindMoreButtons(btnSel, sectionSel) {
    qa(btnSel).forEach(function (btn) {
      btn.addEventListener('click', function () {
        var section = btn.closest(sectionSel);
        if (!section) { return; }
        var expanded = section.classList.toggle('is-expanded');
        btn.textContent = expanded ? '접기' : '더보기';
        btn.setAttribute('aria-expanded', expanded ? 'true' : 'false');
      });
    });
  }

  window.RADAR = {
    onSearchSubmit: onSearchSubmit,
    clearSearch: clearSearch,
    toggleSettings: toggleSettings,
    toggleDashboard: toggleDashboard
  };

  // 스크립트가 body 끝에 있어 DOM은 이미 파싱됨 → 즉시 초기화
  loadSettings();
  loadDashboardOpen();
  buildSettings();
  bindMoreButtons('.curation-more-btn', '.curation-section');
  bindMoreButtons('.community-more-btn', '.community-source-section');
  var input = q('#searchInput');
  if (input) { input.addEventListener('input', function () { runSearch(input.value); }); }
  apply();
})();
</script>

</body>
</html>
