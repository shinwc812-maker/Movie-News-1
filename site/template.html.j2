<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>오늘의 영화/문화 레이더</title>
<style>{{ css|safe }}</style>
</head>
<body class="lang-ko">

{%- macro official_card(a, compact=False) -%}
<article class="card {% if compact %}card-compact{% endif %}">
  {% if a.image_url and not compact %}<img class="thumb" src="{{ a.image_url }}" alt="" loading="lazy" onerror="this.style.display='none'">{% endif %}
  <div class="card-body">
    <a class="title" href="{{ a.url }}" target="_blank" rel="noopener">
      <span class="lang-ko">{{ a.ko_title }}</span><span class="lang-en">{{ a.en_title }}{% if a.country == 'KR' %} <em class="kr-tag">(한국어)</em>{% endif %}</span>
    </a>
    <div class="meta">
      <span class="source official">공식 · {{ a.source }}</span>
      {% if a.rel_time %}<span class="time">{{ a.rel_time }}</span>{% endif %}
    </div>
    {% if a.ko_summary or a.en_summary %}
    <p class="summary">
      <span class="lang-ko">{{ a.ko_summary }}</span><span class="lang-en">{{ a.en_summary }}</span>
    </p>
    {% endif %}
    {% if a.matched_keywords %}
    <div class="chips">{% for kw in a.matched_keywords[:3] %}<span>{{ kw }}</span>{% endfor %}</div>
    {% endif %}
  </div>
</article>
{%- endmacro -%}

{%- macro community_card(c) -%}
<article class="community-snapshot-card">
  <div class="community-topline">
    <span>{{ c.source }}</span>
    {% if c.rel_time %}<em>{{ c.rel_time }}</em>{% endif %}
  </div>
  <a class="community-title" href="{{ c.url }}" target="_blank" rel="noopener">{{ c.title }}</a>
  {% if c.mood_summary %}<p class="community-mood">{{ c.mood_summary }}</p>{% endif %}
  {% if c.excerpt %}<p class="community-excerpt">{{ c.excerpt }}</p>{% endif %}
  {% if c.matched_keywords %}
  <div class="trend-meta community-keywords">{% for kw in c.matched_keywords[:3] %}<b>{{ kw }}</b>{% endfor %}</div>
  {% endif %}
</article>
{%- endmacro -%}

{%- macro curation_brief_card(item) -%}
<article class="curation-brief-card">
  <a class="title curation-article-title" href="{{ item.url }}" target="_blank" rel="noopener">{{ item.curation_title or item.title }}</a>
  {% if item.curation_summary %}
  <div class="curation-summary-block">
    <b>내용 요약</b>
    <p>{{ item.curation_summary }}</p>
  </div>
  {% endif %}
  <div class="brief-card-meta">
    <span class="source {% if item.content_kind == 'policy' %}policy{% else %}official{% endif %}">
      {% if item.content_kind == 'policy' %}정책{% else %}공식{% endif %} · {{ item.source }}
    </span>
    {% if item.rel_time %}<span class="time">{{ item.rel_time }}</span>{% endif %}
  </div>
  {% if item.matched_keywords %}
  <div class="chips">{% for kw in item.matched_keywords[:3] %}<span>{{ kw }}</span>{% endfor %}</div>
  {% endif %}
</article>
{%- endmacro -%}

{%- macro market_trend_card(t) -%}
<article class="market-trend-card">
  <div class="trend-topline">
    <span>{{ t.category }}</span>
    {% if t.rel_time %}<em>{{ t.rel_time }}</em>{% endif %}
  </div>
  <a class="trend-title" href="{{ t.url }}" target="_blank" rel="noopener">{{ t.title }}</a>
  {% if t.frame %}<p class="trend-frame">{{ t.frame }}</p>{% endif %}
  {% if t.note %}
  <div class="trend-brief trend-note">
    <b>요약</b>
    <p>{{ t.note|replace('내용: ', '') }}</p>
  </div>
  {% endif %}
  <div class="trend-meta">
    <span>{{ t.source }}</span>
    {% for keyword in t.keywords[:3] %}<b>{{ keyword }}</b>{% endfor %}
  </div>
</article>
{%- endmacro -%}

<header class="topbar">
  <div>
    <p class="eyebrow">Internal Briefing</p>
    <h1>오늘의 영화/문화 레이더</h1>
    <p class="updated">마지막 업데이트: {{ updated_at }} (KST)</p>
  </div>
  <div class="lang-toggle" aria-label="언어 선택">
    <button class="lang-btn" data-lang="en" onclick="setLang('en')">원문</button>
    <button class="lang-btn active" data-lang="ko" onclick="setLang('ko')">한국어</button>
  </div>
</header>

<main class="dashboard">
  <section class="kpis" aria-label="핵심 지표">
    <div class="kpi"><span>전일 1위</span><strong>{% if boxoffice %}{{ boxoffice[0].top_label }}{% else %}데이터 없음{% endif %}</strong></div>
    <div class="kpi"><span>예매 1위</span><strong>{% if reservation.movies %}{{ reservation.movies[0].title }} {{ reservation.movies[0].reservation_label }}{% else %}데이터 없음{% endif %}</strong></div>
    <div class="kpi"><span>시장동향</span><strong>{{ total_market_trends }}건</strong></div>
    <div class="kpi"><span>커뮤니티 반응</span><strong>{{ total_community }}건</strong></div>
  </section>

  <section class="hero-grid">
    <div class="panel curation-panel">
      <div class="panel-head">
        <h2>핵심 큐레이션</h2>
        <span>sectioned executive brief</span>
      </div>
      <div class="curation-sections" data-section-order="흥행·배급|극장·정책|경쟁사·산업|해외·마켓|문화/IP">
        {% for section in curation_sections %}
        <section class="curation-section">
          <div class="curation-section-head">
            <div>
              <h3>{{ section.title }}</h3>
              <span>{{ section.eyebrow }}</span>
            </div>
            <b>{{ section["items"]|length }}건</b>
          </div>
          <div class="curation-section-items">
            {% for item in section["items"] %}{{ curation_brief_card(item) }}{% endfor %}
          </div>
        </section>
        {% endfor %}
        {% if not curation_sections %}<p class="empty">표시할 큐레이션 항목이 없습니다.</p>{% endif %}
      </div>
    </div>

    <aside class="side-stack">
      <section class="panel">
        <div class="panel-head">
          <h2>전일 관객 TOP 5</h2>
          <span>KOBIS</span>
        </div>
        <ol class="boxoffice-list">
          {% for movie in boxoffice %}
          <li>
            <div class="boxoffice-title">
              <b>{{ movie.rank }}</b>
              <span>{{ movie.rank }}위: {{ movie.title }}{% if movie.open_date %} <em>(개봉 {{ movie.open_date }})</em>{% endif %}</span>
            </div>
            <dl class="boxoffice-metrics">
              <div><dt>관객수</dt><dd>{{ movie.audi_count }}명</dd></div>
              <div><dt>전일대비</dt><dd>{{ movie.audi_delta }} / 누적관객수: {{ movie.audi_acc }}명</dd></div>
              {% if movie.seat_metrics_available %}
              <div><dt>좌석</dt><dd>좌석수: {{ movie.seat_count }}석 / 좌점율: {{ movie.seat_share }} / 좌판율: {{ movie.seat_sales_rate }}</dd></div>
              {% else %}
              <div><dt>좌석</dt><dd>좌석 데이터 없음</dd></div>
              {% endif %}
            </dl>
          </li>
          {% endfor %}
        </ol>
        {% if not boxoffice %}<p class="empty">KOBIS 박스오피스 데이터가 없습니다.</p>{% endif %}
      </section>

      <section class="panel">
        <div class="panel-head">
          <h2>실시간 예매량 TOP 5</h2>
          <span>예매량(예매율)</span>
        </div>
        <ol class="reservation-list">
          {% for movie in reservation.movies %}
          <li>
            <b>{{ movie.rank }}</b>
            <span>{{ movie.title }}</span>
            <strong>{{ movie.reservation_label }}</strong>
          </li>
          {% endfor %}
        </ol>
        {% if not reservation.movies %}<p class="empty">KOBIS 예매율 데이터가 없습니다.</p>{% endif %}
      </section>

      <section class="panel">
        <div class="panel-head">
          <h2>해외 주말 TOP 5</h2>
          <span>Box Office Mojo{% if overseas_weekend.weekend_label %} · {{ overseas_weekend.weekend_label }}{% endif %}</span>
        </div>
        <ol class="overseas-weekend-list">
          {% for movie in overseas_weekend.movies %}
          <li>
            <b>{{ movie.rank }}</b>
            {% if movie.url %}
            <a href="{{ movie.url }}" target="_blank" rel="noopener">{{ movie.title }}</a>
            {% else %}
            <span>{{ movie.title }}</span>
            {% endif %}
            <strong>{{ movie.gross }}</strong>
          </li>
          {% endfor %}
        </ol>
        {% if not overseas_weekend.movies %}<p class="empty">Box Office Mojo 데이터가 없습니다.</p>{% endif %}
      </section>
    </aside>
  </section>

  <section class="panel market-trends-panel">
    <div class="panel-head">
      <h2>시장동향 / Live·IP·팝업</h2>
      <span>experience business scan</span>
    </div>
    <div class="section-stack market-section-stack">
      {% for section in market_trend_sections %}
      <section class="briefing-subsection">
        <div class="section-head">
          <h3>{{ section.title }}</h3>
          <span>{{ section.count }}건</span>
        </div>
        <div class="market-trends-grid section-card-grid">
          {% for trend in section["items"] %}{{ market_trend_card(trend) }}{% endfor %}
        </div>
      </section>
      {% endfor %}
    </div>
    {% if not market_trends %}<p class="empty">표시할 시장동향 스크랩이 없습니다.</p>{% endif %}
  </section>

  <section class="community-only-panel">
    <div class="panel">
      <div class="panel-head">
        <h2>커뮤니티 반응</h2>
        <span>본문/댓글 분위기 요약</span>
      </div>
      <div class="section-stack community-sections">
        {% for section in community_sections %}
        <section class="briefing-subsection community-source-section">
          <div class="section-head">
            <h3>{{ section.title }}</h3>
            <span>{{ section.count }}건</span>
          </div>
          <div class="community-card-grid section-card-grid">
            {% for reaction in section["items"] %}{{ community_card(reaction) }}{% endfor %}
          </div>
        </section>
        {% endfor %}
        {% if not community_reactions %}<p class="empty">표시할 커뮤니티 반응이 없습니다.</p>{% endif %}
      </div>
    </div>
  </section>

  <section class="panel policy-panel">
    <div class="panel-head">
      <h2>정책/지원</h2>
      <span>영화·문화 공공 지원</span>
    </div>
    <div class="policy-grid">
      {% for policy in policy_items[:8] %}
      <a class="policy-card" href="{{ policy.url }}" target="_blank" rel="noopener">
        <span>{{ policy.source }} · {{ policy.category }}</span>
        <strong>{{ policy.title }}</strong>
        {% if policy.summary %}<em>{{ policy.summary }}</em>{% endif %}
      </a>
      {% endfor %}
    </div>
    {% if not policy_items %}<p class="empty">표시할 정책/지원 공지가 없습니다.</p>{% endif %}
  </section>
</main>

<footer>내부용 영화/문화 이슈 집계 · 자동 생성</footer>

<script>
function setLang(lang) {
  document.body.classList.remove('lang-ko', 'lang-en');
  document.body.classList.add('lang-' + lang);
  document.querySelectorAll('.lang-btn').forEach(function (button) {
    button.classList.toggle('active', button.dataset.lang === lang);
  });
}
</script>

</body>
</html>
